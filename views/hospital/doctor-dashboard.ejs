<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Doctor Dashboard - Hospital Doctors' Scheduler</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-gray-100 min-h-screen">
    <header class="bg-white shadow-sm border-b">
        <div class="max-w-7xl mx-auto px-2 sm:px-4 py-3 sm:py-4 flex justify-between items-center">
            <div class="flex items-center space-x-2 sm:space-x-3">
                <% if (hospitalLogo) { %>
                <img src="/uploads/logos/<%= hospitalLogo %>" alt="Hospital Logo" class="w-8 h-8 sm:w-10 sm:h-10 rounded-lg object-cover">
                <% } else { %>
                <div class="w-8 h-8 sm:w-10 sm:h-10 bg-teal-600 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 sm:w-6 sm:h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                    </svg>
                </div>
                <% } %>
                <span class="text-lg sm:text-xl font-bold text-gray-800">Doctor Portal</span>
            </div>
            <div class="flex items-center space-x-2 sm:space-x-4">
                <span class="text-xs sm:text-base text-gray-600 hidden sm:inline">Dr. <%= doctor.name %></span>
                <a href="/<%= hospital %>/doctor/logout" class="bg-gray-200 px-2 sm:px-4 py-2 rounded-lg text-gray-700 hover:bg-gray-300 transition text-sm">Logout</a>
            </div>
        </div>
    </header>

    <div class="max-w-7xl mx-auto px-2 sm:px-4 py-4 sm:py-8">
        <h1 class="text-2xl font-bold text-gray-800 mb-8">Doctor Dashboard</h1>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6 mb-6 sm:mb-8">
            <div class="bg-white rounded-xl shadow-sm p-6 border">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-gray-500 text-sm">Today's Appointments</p>
                        <p class="text-3xl font-bold text-gray-800 mt-1"><%= todayAppointments.length %></p>
                    </div>
                    <div class="w-10 h-10 bg-teal-100 rounded-full flex items-center justify-center">
                        <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                    </div>
                </div>
            </div>
            <div class="bg-white rounded-xl shadow-sm p-6 border">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-gray-500 text-sm">Upcoming</p>
                        <p class="text-3xl font-bold text-gray-800 mt-1"><%= upcomingAppointments.length %></p>
                    </div>
                    <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
                        <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                </div>
            </div>
            <div class="bg-white rounded-xl shadow-sm p-6 border">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-gray-500 text-sm">Past</p>
                        <p class="text-3xl font-bold text-gray-800 mt-1"><%= pastAppointments.length %></p>
                    </div>
                    <div class="w-10 h-10 bg-purple-100 rounded-full flex items-center justify-center">
                        <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                        </svg>
                    </div>
                </div>
            </div>
        </div>

        <!-- Today's Appointments -->
        <div class="bg-white rounded-xl shadow-sm border mb-6 sm:mb-8">
            <div class="px-6 py-4 border-b">
                <h2 class="text-xl font-bold text-gray-800">Today's Appointments</h2>
            </div>
            <div class="p-6">
                <% if (todayAppointments.length > 0) { %>
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead>
                                <tr class="text-left text-gray-500 text-sm">
                                    <th class="pb-3">Time</th>
                                    <th class="pb-3">Patient</th>
                                    <th class="pb-3">Phone</th>
                                    <th class="pb-3">Reason</th>
                                    <th class="pb-3">Status</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y">
                                <% todayAppointments.forEach(function(apt) { %>
                                <tr>
                                    <td class="py-3 font-medium"><%= apt.time %></td>
                                    <td class="py-3"><%= apt.patient_name %></td>
                                    <td class="py-3"><%= apt.patient_phone %></td>
                                    <td class="py-3 text-gray-500"><%= apt.reason %></td>
                                    <td class="py-3">
                                        <span class="px-3 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-700">
                                            <%= apt.status %>
                                        </span>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <p class="text-gray-500 text-center py-8">No appointments scheduled for today</p>
                <% } %>
            </div>
        </div>

        <!-- Upcoming Appointments -->
        <div class="bg-white rounded-xl shadow-sm border mb-6 sm:mb-8">
            <div class="px-6 py-4 border-b">
                <h2 class="text-xl font-bold text-gray-800">Upcoming Appointments</h2>
            </div>
            <div class="p-6">
                <% if (upcomingAppointments.length > 0) { %>
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead>
                                <tr class="text-left text-gray-500 text-sm">
                                    <th class="pb-3">Date</th>
                                    <th class="pb-3">Time</th>
                                    <th class="pb-3">Patient</th>
                                    <th class="pb-3">Phone</th>
                                    <th class="pb-3">Reason</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y">
                                <% upcomingAppointments.forEach(function(apt) { %>
                                <tr>
                                    <td class="py-3"><%= apt.date.split('-').reverse().join('/') %></td>
                                    <td class="py-3 font-medium"><%= apt.time %></td>
                                    <td class="py-3"><%= apt.patient_name %></td>
                                    <td class="py-3"><%= apt.patient_phone %></td>
                                    <td class="py-3 text-gray-500"><%= apt.reason %></td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <p class="text-gray-500 text-center py-8">No upcoming appointments</p>
                <% } %>
            </div>
        </div>

        <!-- Past Appointments -->
        <div class="bg-white rounded-xl shadow-sm border">
            <div class="px-6 py-4 border-b">
                <h2 class="text-xl font-bold text-gray-800">Past Appointments</h2>
            </div>
            <div class="p-6">
                <% if (pastAppointments.length > 0) { %>
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead>
                                <tr class="text-left text-gray-500 text-sm">
                                    <th class="pb-3">Date</th>
                                    <th class="pb-3">Time</th>
                                    <th class="pb-3">Patient</th>
                                    <th class="pb-3">Phone</th>
                                    <th class="pb-3">Reason</th>
                                    <th class="pb-3">Status</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y">
                                <% pastAppointments.forEach(function(apt) { %>
                                <tr>
                                    <td class="py-3"><%= apt.date.split('-').reverse().join('/') %></td>
                                    <td class="py-3 font-medium"><%= apt.time %></td>
                                    <td class="py-3"><%= apt.patient_name %></td>
                                    <td class="py-3"><%= apt.patient_phone %></td>
                                    <td class="py-3 text-gray-500"><%= apt.reason %></td>
                                    <td class="py-3">
                                        <span class="px-3 py-1 rounded-full text-xs font-medium
                                            <%= apt.status === 'completed' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                                            <%= apt.status %>
                                        </span>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <p class="text-gray-500 text-center py-8">No past appointments</p>
                <% } %>
            </div>
        </div>
    </div>
</body>
</html>
