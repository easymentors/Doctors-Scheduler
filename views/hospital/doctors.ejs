<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Doctors Management - Hospital Doctors' Scheduler</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-gray-100 min-h-screen">
    <header class="bg-white shadow-sm border-b">
        <div class="max-w-7xl mx-auto px-2 sm:px-4 py-3 sm:py-4 flex justify-between items-center">
            <div class="flex items-center space-x-2 sm:space-x-3">
                <div class="w-8 h-8 sm:w-10 sm:h-10 bg-teal-600 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 sm:w-6 sm:h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                    </svg>
                </div>
                <span class="text-lg sm:text-xl font-bold text-gray-800">Hospital Doctors' Scheduler</span>
            </div>
            <div class="flex items-center space-x-2 sm:space-x-4">
                <span class="text-xs sm:text-base text-gray-600 hidden sm:inline"><%= user.name %></span>
                <a href="/<%= hospital %>/logout" class="bg-gray-200 px-2 sm:px-4 py-2 rounded-lg text-gray-700 hover:bg-gray-300 transition text-sm">Logout</a>
            </div>
        </div>
    </header>

    <div class="max-w-7xl mx-auto px-2 sm:px-4 py-4 sm:py-8">
        <div class="flex flex-nowrap sm:flex-wrap sm:space-x-2 gap-2 mb-4 sm:mb-8 overflow-x-auto pb-2 -mx-2 px-2 sm:mx-0 sm:px-0">
            <a href="/<%= hospital %>/admin/dashboard" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">Dashboard</a>
            <a href="/<%= hospital %>/admin/doctors" class="px-3 sm:px-6 py-2 sm:py-3 bg-teal-600 text-white rounded-lg font-medium text-sm sm:text-base whitespace-nowrap">Doctors Management</a>
            <a href="/<%= hospital %>/admin/appointments" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">Appointments</a>
            <a href="/<%= hospital %>/admin/book" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">Book</a>
            <a href="/<%= hospital %>/admin/settings" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">Settings</a>
        </div>

        <div class="bg-white rounded-xl shadow-sm border p-6">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-xl font-bold text-gray-800">Doctors Management</h2>
                <button onclick="openAddModal()" class="bg-teal-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-teal-700 transition">+ Add Doctor</button>
            </div>
            <% if (doctors.length > 0) { %>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <% doctors.forEach(function(doctor) { %>
                    <div class="border rounded-xl p-6 hover:shadow-md transition">
                        <div class="flex justify-between items-start">
                            <div class="flex-1">
                                <h3 class="font-bold text-lg text-gray-800"><%= doctor.name_en %></h3>
                                <p class="text-teal-600 font-medium"><%= doctor.specialization_en %></p>
                            </div>
                            <div class="flex space-x-2">
                                <button onclick='openEditModal("<%= doctor.id %>", "<%= doctor.name_en %>", "<%= doctor.specialization_en %>", "<%= doctor.phone || '' %>", "<%= doctor.email || '' %>", <%- JSON.stringify(doctor.working_hours) %>)' class="text-blue-600 hover:text-blue-800 text-sm font-medium">Edit</button>
                                <button onclick='openDeleteModal("<%= doctor.id %>", "<%= doctor.name_en %>")' class="text-red-600 hover:text-red-800 text-sm font-medium">Delete</button>
                            </div>
                        </div>
                        <p class="text-sm text-gray-500 mt-2">📞 <%= doctor.phone || 'N/A' %></p>
                        <p class="text-sm text-gray-500">✉️ <%= doctor.email || 'N/A' %></p>
                        <% if (doctor.working_hours && doctor.working_hours.days && doctor.working_hours.days.length > 0) { %>
                        <p class="text-sm text-teal-600 mt-2">🕐 <%= formatDays(doctor.working_hours.days) %>: <%= formatTime(doctor.working_hours.startTime) %> - <%= formatTime(doctor.working_hours.endTime) %></p>
                        <% } else { %>
                        <p class="text-sm text-gray-400 mt-2">🕐 Not set</p>
                        <% } %>
                    </div>
                    <% }); %>
                </div>
            <% } else { %>
                <p class="text-gray-500 text-center py-8">No doctors added yet</p>
            <% } %>
        </div>
    </div>

    <!-- Add Doctor Modal -->
    <div id="addDoctorModal" class="fixed inset-0 bg-black bg-opacity-50 hidden flex items-center justify-center z-50">
        <div class="bg-white rounded-xl p-6 w-full max-w-md mx-4 max-h-[90vh] overflow-y-auto">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-xl font-bold text-gray-800">Add New Doctor</h3>
                <button onclick="closeAddModal()" class="text-gray-500 hover:text-gray-700">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <form method="POST" action="/<%= hospital %>/admin/doctors/add" class="space-y-4">
                <div>
                    <label class="block text-gray-700 font-medium mb-2">Doctor Name *</label>
                    <input type="text" name="name_en" required class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                </div>
                <div>
                    <label class="block text-gray-700 font-medium mb-2">Specialization *</label>
                    <input type="text" name="specialization_en" required class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                </div>
                <div>
                    <label class="block text-gray-700 font-medium mb-2">Phone</label>
                    <input type="tel" name="phone" class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                </div>
                <div>
                    <label class="block text-gray-700 font-medium mb-2">Email</label>
                    <input type="email" name="email" class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                </div>
                <div class="border-t pt-4">
                    <label class="block text-gray-700 font-medium mb-2">Availability</label>
                    <div class="space-y-3">
                        <div>
                            <label class="block text-gray-600 text-sm mb-1">Select Days</label>
                            <div class="flex flex-wrap gap-2">
                                <label class="flex items-center space-x-1 cursor-pointer">
                                    <input type="checkbox" name="workingDays" value="monday" class="w-4 h-4 text-teal-600 rounded">
                                    <span class="text-sm">Mon</span>
                                </label>
                                <label class="flex items-center space-x-1 cursor-pointer">
                                    <input type="checkbox" name="workingDays" value="tuesday" class="w-4 h-4 text-teal-600 rounded">
                                    <span class="text-sm">Tue</span>
                                </label>
                                <label class="flex items-center space-x-1 cursor-pointer">
                                    <input type="checkbox" name="workingDays" value="wednesday" class="w-4 h-4 text-teal-600 rounded">
                                    <span class="text-sm">Wed</span>
                                </label>
                                <label class="flex items-center space-x-1 cursor-pointer">
                                    <input type="checkbox" name="workingDays" value="thursday" class="w-4 h-4 text-teal-600 rounded">
                                    <span class="text-sm">Thu</span>
                                </label>
                                <label class="flex items-center space-x-1 cursor-pointer">
                                    <input type="checkbox" name="workingDays" value="friday" class="w-4 h-4 text-teal-600 rounded">
                                    <span class="text-sm">Fri</span>
                                </label>
                                <label class="flex items-center space-x-1 cursor-pointer">
                                    <input type="checkbox" name="workingDays" value="saturday" class="w-4 h-4 text-teal-600 rounded">
                                    <span class="text-sm">Sat</span>
                                </label>
                                <label class="flex items-center space-x-1 cursor-pointer">
                                    <input type="checkbox" name="workingDays" value="sunday" class="w-4 h-4 text-teal-600 rounded">
                                    <span class="text-sm">Sun</span>
                                </label>
                            </div>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-gray-600 text-sm mb-1">Start Time</label>
                                <input type="time" name="startTime" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 text-sm">
                            </div>
                            <div>
                                <label class="block text-gray-600 text-sm mb-1">End Time</label>
                                <input type="time" name="endTime" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 text-sm">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="flex space-x-4">
                    <button type="submit" class="flex-1 bg-teal-600 text-white py-3 rounded-lg font-medium hover:bg-teal-700 transition">Add Doctor</button>
                    <button type="button" onclick="closeAddModal()" class="flex-1 bg-gray-200 text-gray-700 py-3 rounded-lg font-medium hover:bg-gray-300 transition">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit Doctor Modal -->
    <div id="editDoctorModal" class="fixed inset-0 bg-black bg-opacity-50 hidden flex items-center justify-center z-50">
        <div class="bg-white rounded-xl p-6 w-full max-w-md mx-4 max-h-[90vh] overflow-y-auto">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-xl font-bold text-gray-800">Edit Doctor</h3>
                <button onclick="closeEditModal()" class="text-gray-500 hover:text-gray-700">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <form id="editDoctorForm" method="POST" class="space-y-4">
                <div>
                    <label class="block text-gray-700 font-medium mb-2">Doctor Name *</label>
                    <input type="text" name="name_en" id="editNameEn" required class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                </div>
                <div>
                    <label class="block text-gray-700 font-medium mb-2">Specialization *</label>
                    <input type="text" name="specialization_en" id="editSpecialization" required class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                </div>
                <div>
                    <label class="block text-gray-700 font-medium mb-2">Phone</label>
                    <input type="tel" name="phone" id="editPhone" class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                </div>
                <div>
                    <label class="block text-gray-700 font-medium mb-2">Email</label>
                    <input type="email" name="email" id="editEmail" class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                </div>
                <div class="border-t pt-4">
                    <label class="block text-gray-700 font-medium mb-2">Availability</label>
                    <div class="space-y-3">
                        <div>
                            <label class="block text-gray-600 text-sm mb-1">Select Days</label>
                            <div class="flex flex-wrap gap-2">
                                <label class="flex items-center space-x-1 cursor-pointer">
                                    <input type="checkbox" name="workingDays" value="monday" class="w-4 h-4 text-teal-600 rounded edit-day-checkbox">
                                    <span class="text-sm">Mon</span>
                                </label>
                                <label class="flex items-center space-x-1 cursor-pointer">
                                    <input type="checkbox" name="workingDays" value="tuesday" class="w-4 h-4 text-teal-600 rounded edit-day-checkbox">
                                    <span class="text-sm">Tue</span>
                                </label>
                                <label class="flex items-center space-x-1 cursor-pointer">
                                    <input type="checkbox" name="workingDays" value="wednesday" class="w-4 h-4 text-teal-600 rounded edit-day-checkbox">
                                    <span class="text-sm">Wed</span>
                                </label>
                                <label class="flex items-center space-x-1 cursor-pointer">
                                    <input type="checkbox" name="workingDays" value="thursday" class="w-4 h-4 text-teal-600 rounded edit-day-checkbox">
                                    <span class="text-sm">Thu</span>
                                </label>
                                <label class="flex items-center space-x-1 cursor-pointer">
                                    <input type="checkbox" name="workingDays" value="friday" class="w-4 h-4 text-teal-600 rounded edit-day-checkbox">
                                    <span class="text-sm">Fri</span>
                                </label>
                                <label class="flex items-center space-x-1 cursor-pointer">
                                    <input type="checkbox" name="workingDays" value="saturday" class="w-4 h-4 text-teal-600 rounded edit-day-checkbox">
                                    <span class="text-sm">Sat</span>
                                </label>
                                <label class="flex items-center space-x-1 cursor-pointer">
                                    <input type="checkbox" name="workingDays" value="sunday" class="w-4 h-4 text-teal-600 rounded edit-day-checkbox">
                                    <span class="text-sm">Sun</span>
                                </label>
                            </div>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-gray-600 text-sm mb-1">Start Time</label>
                                <input type="time" name="startTime" id="editStartTime" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 text-sm">
                            </div>
                            <div>
                                <label class="block text-gray-600 text-sm mb-1">End Time</label>
                                <input type="time" name="endTime" id="editEndTime" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 text-sm">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="flex space-x-4">
                    <button type="submit" class="flex-1 bg-teal-600 text-white py-3 rounded-lg font-medium hover:bg-teal-700 transition">Update Doctor</button>
                    <button type="button" onclick="closeEditModal()" class="flex-1 bg-gray-200 text-gray-700 py-3 rounded-lg font-medium hover:bg-gray-300 transition">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div id="deleteDoctorModal" class="fixed inset-0 bg-black bg-opacity-50 hidden flex items-center justify-center z-50">
        <div class="bg-white rounded-xl p-6 w-full max-w-sm mx-4">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-xl font-bold text-gray-800">Delete Doctor</h3>
                <button onclick="closeDeleteModal()" class="text-gray-500 hover:text-gray-700">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <p class="text-gray-600 mb-6">Are you sure you want to delete <span id="deleteDoctorName" class="font-semibold text-gray-800"></span>? This action cannot be undone.</p>
            <form id="deleteDoctorForm" method="POST" class="flex space-x-4">
                <button type="submit" class="flex-1 bg-red-600 text-white py-3 rounded-lg font-medium hover:bg-red-700 transition">Delete</button>
                <button type="button" onclick="closeDeleteModal()" class="flex-1 bg-gray-200 text-gray-700 py-3 rounded-lg font-medium hover:bg-gray-300 transition">Cancel</button>
            </form>
        </div>
    </div>

    <script>
        function formatDays(days) {
            if (!days || days.length === 0) return 'Not set';
            if (days.length === 7) return 'Every day';
            const dayMap = { monday: 'Mon', tuesday: 'Tue', wednesday: 'Wed', thursday: 'Thu', friday: 'Fri', saturday: 'Sat', sunday: 'Sun' };
            const sortedDays = days.sort((a, b) => ['monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday', 'sunday'].indexOf(a) - ['monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday', 'sunday'].indexOf(b));
            return sortedDays.map(d => dayMap[d]).join('-');
        }

        function formatTime(time) {
            if (!time) return '';
            const [hours, minutes] = time.split(':');
            const h = parseInt(hours);
            return (h > 12 ? h - 12 : (h === 0 ? 12 : h)) + ':' + minutes + (h >= 12 ? ' PM' : ' AM');
        }

        function openAddModal() {
            document.getElementById('addDoctorModal').classList.remove('hidden');
        }

        function closeAddModal() {
            document.getElementById('addDoctorModal').classList.add('hidden');
        }

        function openEditModal(id, name, spec, phone, email, workingHours) {
            document.getElementById('editDoctorForm').action = '/<%= hospital %>/admin/doctors/' + id + '/update';
            document.getElementById('editNameEn').value = name;
            document.getElementById('editSpecialization').value = spec;
            document.getElementById('editPhone').value = phone;
            document.getElementById('editEmail').value = email;
            
            document.querySelectorAll('.edit-day-checkbox').forEach(cb => cb.checked = false);
            if (workingHours && workingHours.days) {
                workingHours.days.forEach(day => {
                    document.querySelectorAll('.edit-day-checkbox').forEach(cb => {
                        if (cb.value === day) cb.checked = true;
                    });
                });
                document.getElementById('editStartTime').value = workingHours.startTime || '';
                document.getElementById('editEndTime').value = workingHours.endTime || '';
            }
            
            document.getElementById('editDoctorModal').classList.remove('hidden');
        }

        function closeEditModal() {
            document.getElementById('editDoctorModal').classList.add('hidden');
        }

        function openDeleteModal(id, name) {
            document.getElementById('deleteDoctorForm').action = '/<%= hospital %>/admin/doctors/' + id + '/delete';
            document.getElementById('deleteDoctorName').textContent = name;
            document.getElementById('deleteDoctorModal').classList.remove('hidden');
        }

        function closeDeleteModal() {
            document.getElementById('deleteDoctorModal').classList.add('hidden');
        }
    </script>
</body>
</html>
