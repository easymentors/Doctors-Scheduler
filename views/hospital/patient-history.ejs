<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Patients Appointment History - Hospital Doctors' Scheduler</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-gray-100 min-h-screen">
    <header class="bg-white shadow-sm border-b">
        <div class="max-w-7xl mx-auto px-2 sm:px-4 py-3 sm:py-4 flex justify-between items-center">
            <div class="flex items-center space-x-2 sm:space-x-3">
                <% if (hospitalLogo) { %>
                <img src="/uploads/logos/<%= hospitalLogo %>" alt="Hospital Logo" class="w-8 h-8 sm:w-10 sm:h-10 rounded-lg object-cover">
                <% } else { %>
                <div class="w-8 h-8 sm:w-10 sm:h-10 bg-teal-600 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 sm:w-6 sm:h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                    </svg>
                </div>
                <% } %>
                <span class="text-lg sm:text-xl font-bold text-gray-800">Welcome to <%= hospitalName %> Doctors' Scheduler</span>
            </div>
            <div class="flex items-center space-x-2 sm:space-x-4">
                <span class="text-xs sm:text-base text-gray-600 hidden sm:inline"><%= user.name %></span>
                <a href="/<%= hospital %>/logout" class="bg-gray-200 px-2 sm:px-4 py-2 rounded-lg text-gray-700 hover:bg-gray-300 transition text-sm">Logout</a>
            </div>
        </div>
    </header>

    <div class="max-w-7xl mx-auto px-2 sm:px-4 py-4 sm:py-8">
        <div class="flex flex-nowrap sm:flex-wrap sm:space-x-2 gap-2 mb-4 sm:mb-8 overflow-x-auto pb-2 -mx-2 px-2 sm:mx-0 sm:px-0">
            <a href="/<%= hospital %>/admin/dashboard" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">Dashboard</a>
            <a href="/<%= hospital %>/admin/doctors" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">Doctors Management</a>
            <a href="/<%= hospital %>/admin/appointments" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">See all Appointments</a>
            <a href="/<%= hospital %>/admin/book" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">Book Appointment</a>
            <a href="/<%= hospital %>/admin/settings" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">Settings</a>
            <a href="/<%= hospital %>/admin/patient-history" class="px-3 sm:px-6 py-2 sm:py-3 bg-orange-600 text-white rounded-lg font-medium text-sm sm:text-base whitespace-nowrap">Patients Appointment History</a>
        </div>

        <div class="bg-white rounded-xl shadow-sm border p-4 sm:p-6 mb-6">
            <h2 class="text-xl font-bold text-gray-800 mb-4">Patients Appointment History</h2>
            
            <form method="GET" action="/<%= hospital %>/admin/patient-history" class="flex flex-wrap gap-4 items-end">
                <div>
                    <label class="block text-gray-600 text-sm mb-1">From Date</label>
                    <input type="date" name="dateFrom" value="<%= selectedDateFrom %>" class="px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 text-sm">
                </div>
                <div>
                    <label class="block text-gray-600 text-sm mb-1">To Date</label>
                    <input type="date" name="dateTo" value="<%= selectedDateTo %>" class="px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 text-sm">
                </div>
                <div>
                    <label class="block text-gray-600 text-sm mb-1">Patient Name</label>
                    <input type="text" name="patientName" value="<%= selectedPatientName %>" placeholder="Search by name" class="px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 text-sm min-w-[180px]">
                </div>
                <div>
                    <label class="block text-gray-600 text-sm mb-1">Phone No</label>
                    <input type="text" name="patientPhone" value="<%= selectedPatientPhone %>" placeholder="Search by phone" class="px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 text-sm min-w-[150px]">
                </div>
                <div>
                    <label class="block text-gray-600 text-sm mb-1">Status</label>
                    <select name="status" class="px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 text-sm">
                        <option value="all" <%= selectedStatus === 'all' ? 'selected' : '' %>>All Status</option>
                        <option value="scheduled" <%= selectedStatus === 'scheduled' ? 'selected' : '' %>>Scheduled</option>
                        <option value="completed" <%= selectedStatus === 'completed' ? 'selected' : '' %>>Completed</option>
                        <option value="cancelled" <%= selectedStatus === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                    </select>
                </div>
                <div class="flex gap-2">
                    <button type="submit" class="bg-teal-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-teal-700 transition text-sm">Filter</button>
                    <a href="/<%= hospital %>/admin/patient-history" class="bg-gray-200 text-gray-700 px-4 py-2 rounded-lg font-medium hover:bg-gray-300 transition text-sm">Clear</a>
                </div>
            </form>
            
            <div class="mt-4 text-gray-500 text-sm">
                <%= appointments.length %> record<%= appointments.length !== 1 ? 's' : '' %> found (sorted alphabetically by patient name)
                <% if (selectedDateFrom || selectedDateTo || selectedPatientName || selectedPatientPhone || (selectedStatus && selectedStatus !== 'all')) { %>
                    <span class="ml-2">| Filters: 
                        <% if (selectedDateFrom || selectedDateTo) { %><span class="bg-blue-100 text-blue-700 px-2 py-0.5 rounded text-xs ml-1">Date: <%= selectedDateFrom ? selectedDateFrom.split('-').reverse().join('/') : '...' %> to <%= selectedDateTo ? selectedDateTo.split('-').reverse().join('/') : '...' %></span><% } %>
                        <% if (selectedPatientName) { %><span class="bg-blue-100 text-blue-700 px-2 py-0.5 rounded text-xs ml-1">Name: <%= selectedPatientName %></span><% } %>
                        <% if (selectedPatientPhone) { %><span class="bg-blue-100 text-blue-700 px-2 py-0.5 rounded text-xs ml-1">Phone: <%= selectedPatientPhone %></span><% } %>
                        <% if (selectedStatus && selectedStatus !== 'all') { %><span class="bg-blue-100 text-blue-700 px-2 py-0.5 rounded text-xs ml-1"><%= selectedStatus %></span><% } %>
                    </span>
                <% } %>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border">
            <div class="p-6">
                <% if (appointments.length > 0) { %>
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead>
                                <tr class="text-left text-gray-500 text-sm border-b">
                                    <th class="pb-3">Date</th>
                                    <th class="pb-3">Time</th>
                                    <th class="pb-3">Doctor</th>
                                    <th class="pb-3">Patient Name</th>
                                    <th class="pb-3">Phone</th>
                                    <th class="pb-3">Reason</th>
                                    <th class="pb-3">Status</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y">
                                <% appointments.forEach(function(apt) { %>
                                <tr>
                                    <td class="py-3"><%= apt.date.split('-').reverse().join('/') %></td>
                                    <td class="py-3 font-medium"><%= apt.time %></td>
                                    <td class="py-3"><%= apt.doctor_name %></td>
                                    <td class="py-3"><%= apt.patient_name %></td>
                                    <td class="py-3"><%= apt.patient_phone %></td>
                                    <td class="py-3 text-gray-500 text-sm"><%= apt.reason || '-' %></td>
                                    <td class="py-3">
                                        <span class="px-3 py-1 rounded-full text-xs font-medium
                                            <%= apt.status === 'scheduled' ? 'bg-blue-100 text-blue-700' : 
                                               apt.status === 'completed' ? 'bg-green-100 text-green-700' : 
                                               'bg-red-100 text-red-700' %>">
                                            <%= apt.status %>
                                        </span>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <p class="text-gray-500 text-center py-8">No appointment records found</p>
                <% } %>
            </div>
        </div>
    </div>
</body>
</html>
