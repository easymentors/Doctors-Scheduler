<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Appointments - Hospital Doctors' Scheduler</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-gray-100 min-h-screen">
    <header class="bg-white shadow-sm border-b">
        <div class="max-w-7xl mx-auto px-2 sm:px-4 py-3 sm:py-4 flex justify-between items-center">
            <div class="flex items-center space-x-2 sm:space-x-3">
                <div class="w-8 h-8 sm:w-10 sm:h-10 bg-teal-600 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 sm:w-6 sm:h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                    </svg>
                </div>
                <span class="text-lg sm:text-xl font-bold text-gray-800">Hospital Doctors' Scheduler</span>
            </div>
            <div class="flex items-center space-x-2 sm:space-x-4">
                <span class="text-xs sm:text-base text-gray-600 hidden sm:inline"><%= user.name %></span>
                <a href="/<%= hospital %>/logout" class="bg-gray-200 px-2 sm:px-4 py-2 rounded-lg text-gray-700 hover:bg-gray-300 transition text-sm">Logout</a>
            </div>
        </div>
    </header>

    <div class="max-w-7xl mx-auto px-2 sm:px-4 py-4 sm:py-8">
        <div class="flex flex-nowrap sm:flex-wrap sm:space-x-2 gap-2 mb-4 sm:mb-8 overflow-x-auto pb-2 -mx-2 px-2 sm:mx-0 sm:px-0">
            <a href="/<%= hospital %>/admin/dashboard" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">Dashboard</a>
            <a href="/<%= hospital %>/admin/doctors" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">Doctors</a>
            <a href="/<%= hospital %>/admin/appointments" class="px-3 sm:px-6 py-2 sm:py-3 bg-teal-600 text-white rounded-lg font-medium text-sm sm:text-base whitespace-nowrap">Appointments</a>
            <a href="/<%= hospital %>/admin/book" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">Book</a>
            <a href="/<%= hospital %>/admin/settings" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">Settings</a>
        </div>

        <div class="bg-white rounded-xl shadow-sm border p-4 sm:p-6 mb-6">
            <h2 class="text-xl font-bold text-gray-800 mb-4">All Appointments</h2>
            
            <!-- Filters -->
            <form method="GET" action="/<%= hospital %>/admin/appointments" class="flex flex-wrap gap-4 items-end">
                <div>
                    <label class="block text-gray-600 text-sm mb-1">Date</label>
                    <input type="date" name="date" value="<%= selectedDate %>" class="px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 text-sm">
                </div>
                <div>
                    <label class="block text-gray-600 text-sm mb-1">Doctor</label>
                    <select name="doctorId" class="px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 text-sm min-w-[180px]">
                        <option value="">All Doctors</option>
                        <% doctors.forEach(function(doc) { %>
                        <option value="<%= doc.id %>" <%= selectedDoctor === doc.id ? 'selected' : '' %>><%= doc.name_en %></option>
                        <% }); %>
                    </select>
                </div>
                <div>
                    <label class="block text-gray-600 text-sm mb-1">Status</label>
                    <select name="status" class="px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 text-sm">
                        <option value="all" <%= selectedStatus === 'all' ? 'selected' : '' %>>All Status</option>
                        <option value="scheduled" <%= selectedStatus === 'scheduled' ? 'selected' : '' %>>Scheduled</option>
                        <option value="completed" <%= selectedStatus === 'completed' ? 'selected' : '' %>>Completed</option>
                        <option value="cancelled" <%= selectedStatus === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                    </select>
                </div>
                <div class="flex gap-2">
                    <button type="submit" class="bg-teal-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-teal-700 transition text-sm">Filter</button>
                    <a href="/<%= hospital %>/admin/appointments" class="bg-gray-200 text-gray-700 px-4 py-2 rounded-lg font-medium hover:bg-gray-300 transition text-sm">Clear</a>
                </div>
            </form>
            
            <div class="mt-4 text-gray-500 text-sm">
                <%= appointments.length %> appointment<%= appointments.length !== 1 ? 's' : '' %> found
                <% if (selectedDate || selectedDoctor || (selectedStatus && selectedStatus !== 'all')) { %>
                    <span class="ml-2">| Filters: 
                        <% if (selectedDate) { %><span class="bg-blue-100 text-blue-700 px-2 py-0.5 rounded text-xs ml-1">Date: <%= selectedDate %></span><% } %>
                        <% if (selectedDoctor) { %><span class="bg-blue-100 text-blue-700 px-2 py-0.5 rounded text-xs ml-1">Doctor</span><% } %>
                        <% if (selectedStatus && selectedStatus !== 'all') { %><span class="bg-blue-100 text-blue-700 px-2 py-0.5 rounded text-xs ml-1"><%= selectedStatus %></span><% } %>
                    </span>
                <% } %>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border">
            <div class="p-6">
                <% if (appointments.length > 0) { %>
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead>
                                <tr class="text-left text-gray-500 text-sm border-b">
                                    <th class="pb-3">Date</th>
                                    <th class="pb-3">Time</th>
                                    <th class="pb-3">Doctor</th>
                                    <th class="pb-3">Patient</th>
                                    <th class="pb-3">Phone</th>
                                    <th class="pb-3">Status</th>
                                    <th class="pb-3">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y">
                                <% appointments.forEach(function(apt) { %>
                                <tr>
                                    <td class="py-3"><%= apt.date.split('-').reverse().join('/') %></td>
                                    <td class="py-3 font-medium"><%= apt.time %></td>
                                    <td class="py-3"><%= apt.doctor_name %></td>
                                    <td class="py-3"><%= apt.patient_name %></td>
                                    <td class="py-3"><%= apt.patient_phone %></td>
                                    <td class="py-3">
                                        <span class="px-3 py-1 rounded-full text-xs font-medium
                                            <%= apt.status === 'scheduled' ? 'bg-blue-100 text-blue-700' : 
                                               apt.status === 'completed' ? 'bg-green-100 text-green-700' : 
                                               'bg-red-100 text-red-700' %>">
                                            <%= apt.status %>
                                        </span>
                                    </td>
                                    <td class="py-3">
                                        <div class="flex space-x-2">
                                            <button onclick="openEditModal('<%= apt.id %>', '<%= apt.doctor_id %>', '<%= apt.patient_name %>', '<%= apt.patient_phone %>', '<%= apt.date %>', '<%= apt.time %>', '<%= apt.reason %>')" class="text-blue-600 hover:text-blue-800 text-sm font-medium">Edit</button>
                                            <% if (apt.status === 'scheduled') { %>
                                            <button onclick="openStatusModal('<%= apt.id %>', 'completed')" class="text-green-600 hover:text-green-800 text-sm font-medium">Complete</button>
                                            <button onclick="openStatusModal('<%= apt.id %>', 'cancelled')" class="text-red-600 hover:text-red-800 text-sm font-medium">Cancel</button>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <p class="text-gray-500 text-center py-8">No appointments yet</p>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Edit Appointment Modal -->
    <div id="editModal" class="fixed inset-0 bg-black bg-opacity-50 hidden flex items-center justify-center z-50">
        <div class="bg-white rounded-xl p-6 w-full max-w-md mx-4">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-xl font-bold text-gray-800">Edit Appointment</h3>
                <button onclick="closeEditModal()" class="text-gray-500 hover:text-gray-700">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <form id="editForm" method="POST" class="space-y-4">
                <div>
                    <label class="block text-gray-700 font-medium mb-2">Select Doctor</label>
                    <select name="doctorId" id="editDoctorId" required class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                        <option value="">-- Select Doctor --</option>
                        <% doctors.forEach(function(doc) { %>
                        <option value="<%= doc.id %>"><%= doc.name_en %> - <%= doc.specialization_en %></option>
                        <% }); %>
                    </select>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-gray-700 font-medium mb-2">Patient Name</label>
                        <input type="text" name="patientName" id="editPatientName" required class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                    </div>
                    <div>
                        <label class="block text-gray-700 font-medium mb-2">Patient Phone</label>
                        <input type="tel" name="patientPhone" id="editPatientPhone" required class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                    </div>
                </div>
                <div>
                    <label class="block text-gray-700 font-medium mb-2">Reason for Visit</label>
                    <input type="text" name="reason" id="editReason" required class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-gray-700 font-medium mb-2">Date</label>
                        <input type="date" name="date" id="editDate" required class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                    </div>
                    <div>
                        <label class="block text-gray-700 font-medium mb-2">Time</label>
                        <input type="time" name="time" id="editTime" required class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                    </div>
                </div>
                <div class="flex space-x-4">
                    <button type="submit" class="flex-1 bg-teal-600 text-white py-3 rounded-lg font-medium hover:bg-teal-700 transition">Update</button>
                    <button type="button" onclick="closeEditModal()" class="flex-1 bg-gray-200 text-gray-700 py-3 rounded-lg font-medium hover:bg-gray-300 transition">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Status Change Modal -->
    <div id="statusModal" class="fixed inset-0 bg-black bg-opacity-50 hidden flex items-center justify-center z-50">
        <div class="bg-white rounded-xl p-6 w-full max-w-sm mx-4">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-xl font-bold text-gray-800">Confirm Action</h3>
                <button onclick="closeStatusModal()" class="text-gray-500 hover:text-gray-700">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <p id="statusMessage" class="text-gray-600 mb-6">Are you sure you want to change the status?</p>
            <form id="statusForm" method="POST" class="flex space-x-4">
                <input type="hidden" name="status" id="statusValue">
                <button type="submit" class="flex-1 bg-teal-600 text-white py-3 rounded-lg font-medium hover:bg-teal-700 transition">Confirm</button>
                <button type="button" onclick="closeStatusModal()" class="flex-1 bg-gray-200 text-gray-700 py-3 rounded-lg font-medium hover:bg-gray-300 transition">Cancel</button>
            </form>
        </div>
    </div>

    <script>
        const allDoctors = <%- JSON.stringify(doctors) %>;
        
        function openEditModal(id, doctorId, patientName, patientPhone, date, time, reason) {
            document.getElementById('editForm').action = '/<%= hospital %>/admin/appointments/' + id + '/update';
            document.getElementById('editDoctorId').value = doctorId;
            document.getElementById('editPatientName').value = patientName;
            document.getElementById('editPatientPhone').value = patientPhone;
            document.getElementById('editDate').value = date;
            document.getElementById('editTime').value = time;
            document.getElementById('editReason').value = reason;
            document.getElementById('editModal').classList.remove('hidden');
        }

        function closeEditModal() {
            document.getElementById('editModal').classList.add('hidden');
        }

        function openStatusModal(id, status) {
            document.getElementById('statusForm').action = '/<%= hospital %>/admin/appointments/' + id + '/status';
            document.getElementById('statusValue').value = status;
            document.getElementById('statusMessage').textContent = status === 'completed' ? 'Mark this appointment as completed?' : 'Are you sure you want to cancel this appointment?';
            document.getElementById('statusModal').classList.remove('hidden');
        }

        function closeStatusModal() {
            document.getElementById('statusModal').classList.add('hidden');
        }

        const today = new Date().toISOString().split('T')[0];
        document.getElementById('editDate').min = today;
    </script>
</body>
</html>
