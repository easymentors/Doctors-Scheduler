<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Doctors - Hospital Doctors Scheduler</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .nav-scroll::-webkit-scrollbar { display: none; }
    </style>
</head>
<body class="bg-gray-100 min-h-screen">
    <!-- Header -->
    <header class="bg-white shadow-sm border-b">
        <div class="max-w-7xl mx-auto px-2 sm:px-4 py-3 sm:py-4 flex justify-between items-center">
            <div class="flex items-center space-x-2 sm:space-x-3">
                <div class="w-8 h-8 sm:w-10 sm:h-10 bg-teal-600 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 sm:w-6 sm:h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                    </svg>
                </div>
                <span class="text-lg sm:text-xl font-bold text-gray-800">Hospital Doctors' Scheduler</span>
            </div>
            <div class="flex items-center space-x-2 sm:space-x-4">
                <span class="text-xs sm:text-base text-gray-600 hidden sm:inline"><%= user.name %></span>
                <a href="/logout" class="bg-gray-200 px-2 sm:px-4 py-2 rounded-lg text-gray-700 hover:bg-gray-300 transition text-sm">Logout</a>
            </div>
        </div>
    </header>

    <div class="max-w-7xl mx-auto px-2 sm:px-4 py-4 sm:py-8">
        <!-- Navigation -->
        <div class="flex flex-nowrap sm:flex-wrap sm:space-x-2 gap-2 mb-4 sm:mb-8 overflow-x-auto pb-2 -mx-2 px-2 sm:mx-0 sm:px-0">
            <a href="/admin/dashboard" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">Dashboard</a>
            <a href="/admin/doctors" class="px-3 sm:px-6 py-2 sm:py-3 bg-teal-600 text-white rounded-lg font-medium text-sm sm:text-base whitespace-nowrap">Doctors</a>
            <a href="/admin/appointments" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">Appointments</a>
            <a href="/admin/book" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">Book</a>
            <% if (user.role === 'admin') { %>
            <a href="/admin/doctor-report" class="px-3 sm:px-6 py-2 sm:py-3 bg-purple-100 text-purple-700 rounded-lg font-medium hover:bg-purple-200 text-sm sm:text-base whitespace-nowrap">Doctor Report</a>
            <a href="/admin/patient-report" class="px-3 sm:px-6 py-2 sm:py-3 bg-purple-100 text-purple-700 rounded-lg font-medium hover:bg-purple-200 text-sm sm:text-base whitespace-nowrap">Patient Report</a>
            <a href="/admin/settings" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">Settings</a>
            <% } %>
        </div>

        <!-- Add Doctor Button -->
        <div class="mb-4 sm:mb-6">
            <button onclick="showAddModal()" class="bg-teal-600 text-white px-4 sm:px-6 py-2 sm:py-3 rounded-lg font-medium hover:bg-teal-700 transition w-full sm:w-auto">
                + Add New Doctor
            </button>
        </div>

        <!-- Doctors List -->
        <div class="bg-white rounded-xl shadow-sm border">
            <div class="px-6 py-4 border-b">
                <h2 class="text-xl font-bold text-gray-800">All Doctors</h2>
            </div>
            <div class="p-6">
                <% if (doctors.length > 0) { %>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                        <% doctors.forEach(function(doctor) { %>
                        <div class="border rounded-xl p-6 hover:shadow-md transition">
                            <div class="flex justify-between items-start mb-4">
                                <div>
                                    <h3 class="font-bold text-lg text-gray-800"><%= doctor.name_en %></h3>
                                    <p class="text-teal-600 font-medium"><%= doctor.specialization_en %></p>
                                </div>
                                <span class="bg-teal-100 text-teal-700 px-3 py-1 rounded-full text-sm font-medium"><%= doctor.id %></span>
                            </div>
                            <div class="space-y-2 text-sm text-gray-600 mb-4">
                                <p>📞 <%= doctor.phone %></p>
                                <p>📧 <%= doctor.email %></p>
                            </div>
                            <div class="border-t pt-4 mb-4">
                                <p class="text-sm text-gray-500 mb-2">Working Hours:</p>
                                <p class="text-sm"><%= doctor.workingHours.start %> - <%= doctor.workingHours.end %></p>
                                <p class="text-sm"><%= doctor.workingHours.slotDuration %> min slots</p>
                                <p class="text-sm"><%= doctor.workingHours.days.join(', ') %></p>
                            </div>
                            <div class="flex space-x-2">
                                <button onclick="showEditModal('<%= doctor.id %>')" class="flex-1 bg-blue-100 text-blue-700 py-2 rounded-lg hover:bg-blue-200 transition text-sm">Edit</button>
                                <button onclick="deleteDoctor('<%= doctor.id %>')" class="flex-1 bg-red-100 text-red-700 py-2 rounded-lg hover:bg-red-200 transition text-sm">Delete</button>
                            </div>
                        </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <p class="text-gray-500 text-center py-8">No doctors added yet</p>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Add/Edit Doctor Modal -->
    <div id="doctorModal" class="fixed inset-0 bg-black/50 hidden flex items-center justify-center p-4 z-50">
        <div class="bg-white rounded-xl max-w-2xl w-full max-h-[90vh] overflow-y-auto">
            <div class="px-6 py-4 border-b flex justify-between items-center">
                <h3 class="text-xl font-bold text-gray-800" id="modalTitle">Add New Doctor</h3>
                <button onclick="closeModal()" class="text-gray-500 hover:text-gray-700">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
            <form id="doctorForm" method="POST" class="p-6 space-y-6">
                <input type="hidden" id="doctorId" name="doctorId">
                
                <div>
                    <label class="block text-gray-700 font-medium mb-2">Name</label>
                    <input type="text" name="name_en" required class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                </div>
                
                <div>
                    <label class="block text-gray-700 font-medium mb-2">Specialization</label>
                    <input type="text" name="specialization_en" required class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-gray-700 font-medium mb-2">Phone</label>
                        <input type="text" name="phone" required class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                    </div>
                    <div>
                        <label class="block text-gray-700 font-medium mb-2">Email</label>
                        <input type="email" name="email" class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                    </div>
                </div>

                <div class="border-t pt-4">
                    <h4 class="font-medium text-gray-800 mb-4">Working Hours</h4>
                    <div class="grid grid-cols-3 gap-4">
                        <div>
                            <label class="block text-gray-600 text-sm mb-1">Start Time</label>
                            <input type="time" name="startTime" value="09:00" class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                        </div>
                        <div>
                            <label class="block text-gray-600 text-sm mb-1">End Time</label>
                            <input type="time" name="endTime" value="17:00" class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                        </div>
                        <div>
                            <label class="block text-gray-600 text-sm mb-1">Slot Duration (min)</label>
                            <select name="slotDuration" class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                                <option value="15">15 minutes</option>
                                <option value="30" selected>30 minutes</option>
                                <option value="45">45 minutes</option>
                                <option value="60">60 minutes</option>
                            </select>
                        </div>
                    </div>
                    <div class="mt-4">
                        <label class="block text-gray-600 text-sm mb-2">Working Days</label>
                        <div class="flex flex-wrap gap-2">
                            <% ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'].forEach(function(day) { %>
                            <label class="inline-flex items-center">
                                <input type="checkbox" name="days" value="<%= day %>" class="rounded text-teal-600" <%= ['Mon','Tue','Wed','Thu','Fri'].includes(day) ? 'checked' : '' %>>
                                <span class="ml-2 text-sm"><%= day %></span>
                            </label>
                            <% }); %>
                        </div>
                    </div>
                </div>

                <div>
                    <label class="block text-gray-700 font-medium mb-2">Login Password</label>
                    <input type="text" name="password" placeholder="Leave blank to keep current" class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                </div>

                <div class="flex space-x-4">
                    <button type="submit" class="flex-1 bg-teal-600 text-white py-3 rounded-lg font-medium hover:bg-teal-700 transition">Save Doctor</button>
                    <button type="button" onclick="closeModal()" class="flex-1 bg-gray-200 text-gray-700 py-3 rounded-lg font-medium hover:bg-gray-300 transition">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        const doctors = <%- JSON.stringify(doctors) %>;

        function showAddModal() {
            document.getElementById('modalTitle').textContent = 'Add New Doctor';
            document.getElementById('doctorForm').action = '/admin/doctors/add';
            document.getElementById('doctorId').value = '';
            document.getElementById('doctorModal').classList.remove('hidden');
        }

        function showEditModal(id) {
            const doctor = doctors.find(d => d.id === id);
            if (!doctor) return;
            
            document.getElementById('modalTitle').textContent = 'Edit Doctor';
            document.getElementById('doctorForm').action = '/admin/doctors/update/' + id;
            document.getElementById('doctorId').value = doctor.id;
            
            document.querySelector('input[name="name_en"]').value = doctor.name_en;
            document.querySelector('input[name="specialization_en"]').value = doctor.specialization_en;
            document.querySelector('input[name="phone"]').value = doctor.phone;
            document.querySelector('input[name="email"]').value = doctor.email || '';
            
            if (doctor.workingHours) {
                document.querySelector('input[name="startTime"]').value = doctor.workingHours.start;
                document.querySelector('input[name="endTime"]').value = doctor.workingHours.end;
                document.querySelector('select[name="slotDuration"]').value = doctor.workingHours.slotDuration;
                
                document.querySelectorAll('input[name="days"]').forEach(cb => {
                    cb.checked = doctor.workingHours.days.includes(cb.value);
                });
            }
            
            document.getElementById('doctorModal').classList.remove('hidden');
        }

        function closeModal() {
            document.getElementById('doctorModal').classList.add('hidden');
        }

        function deleteDoctor(id) {
            if (confirm('Are you sure you want to delete this doctor?')) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '/admin/doctors/delete/' + id;
                document.body.appendChild(form);
                form.submit();
            }
        }
    </script>
</body>
</html>
