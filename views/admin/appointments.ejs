<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Appointments - Hospital Doctors Scheduler</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .nav-scroll::-webkit-scrollbar { display: none; }
    </style>
</head>
<body class="bg-gray-100 min-h-screen">
    <!-- Header -->
    <header class="bg-white shadow-sm border-b">
        <div class="max-w-7xl mx-auto px-2 sm:px-4 py-3 sm:py-4 flex justify-between items-center">
            <div class="flex items-center space-x-2 sm:space-x-3">
                <div class="w-8 h-8 sm:w-10 sm:h-10 bg-teal-600 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 sm:w-6 sm:h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                    </svg>
                </div>
                <span class="text-lg sm:text-xl font-bold text-gray-800">Hospital Doctors' Scheduler</span>
            </div>
            <div class="flex items-center space-x-2 sm:space-x-4">
                <span class="text-xs sm:text-base text-gray-600 hidden sm:inline"><%= user.name %></span>
                <a href="/logout" class="bg-gray-200 px-2 sm:px-4 py-2 rounded-lg text-gray-700 hover:bg-gray-300 transition text-sm">Logout</a>
            </div>
        </div>
    </header>

    <div class="max-w-7xl mx-auto px-2 sm:px-4 py-4 sm:py-8">
        <!-- Navigation -->
        <div class="flex flex-nowrap sm:flex-wrap sm:space-x-2 gap-2 mb-4 sm:mb-8 overflow-x-auto pb-2 -mx-2 px-2 sm:mx-0 sm:px-0">
            <a href="/admin/dashboard" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">Dashboard</a>
            <% if (user.role === 'admin') { %>
            <a href="/admin/doctors" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">Doctors</a>
            <a href="/admin/doctor-report" class="px-3 sm:px-6 py-2 sm:py-3 bg-purple-100 text-purple-700 rounded-lg font-medium hover:bg-purple-200 text-sm sm:text-base whitespace-nowrap">Doctor Report</a>
            <a href="/admin/patient-report" class="px-3 sm:px-6 py-2 sm:py-3 bg-purple-100 text-purple-700 rounded-lg font-medium hover:bg-purple-200 text-sm sm:text-base whitespace-nowrap">Patient Report</a>
            <% } %>
            <a href="/admin/appointments" class="px-3 sm:px-6 py-2 sm:py-3 bg-teal-600 text-white rounded-lg font-medium text-sm sm:text-base whitespace-nowrap">Appointments</a>
            <a href="/admin/book" class="px-3 sm:px-6 py-2 sm:py-3 bg-teal-100 text-teal-700 rounded-lg font-medium hover:bg-teal-200 text-sm sm:text-base whitespace-nowrap">Book</a>
            <% if (user.role === 'admin') { %>
            <a href="/admin/settings" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">Settings</a>
            <% } %>
        </div>

        <!-- Filters -->
        <div class="bg-white rounded-xl shadow-sm border p-4 sm:p-6 mb-6">
            <form method="GET" action="/admin/appointments" class="flex flex-wrap gap-3 sm:gap-4 items-end">
                <div>
                    <label class="block text-gray-600 text-sm mb-1">Doctor</label>
                    <select name="doctor" class="px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                        <option value="">All Doctors</option>
                        <% doctors.forEach(function(doc) { %>
                        <option value="<%= doc.id %>" <%= filters.doctor === doc.id ? 'selected' : '' %>><%= doc.name_en %></option>
                        <% }); %>
                    </select>
                </div>
                <div>
                    <label class="block text-gray-600 text-sm mb-1">Date</label>
                    <input type="date" name="date" value="<%= filters.date || '' %>" class="px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                </div>
                <div>
                    <label class="block text-gray-600 text-sm mb-1">Status</label>
                    <select name="status" class="px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                        <option value="">All Status</option>
                        <option value="scheduled" <%= filters.status === 'scheduled' ? 'selected' : '' %>>Scheduled</option>
                        <option value="completed" <%= filters.status === 'completed' ? 'selected' : '' %>>Completed</option>
                        <option value="cancelled" <%= filters.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                    </select>
                </div>
                <button type="submit" class="bg-teal-600 text-white px-6 py-2 rounded-lg hover:bg-teal-700 transition">Filter</button>
                <a href="/admin/appointments" class="bg-gray-200 text-gray-700 px-6 py-2 rounded-lg hover:bg-gray-300 transition">Clear</a>
            </form>
        </div>

        <!-- Appointments Table -->
        <div class="bg-white rounded-xl shadow-sm border">
            <div class="px-6 py-4 border-b flex justify-between items-center">
                <h2 class="text-xl font-bold text-gray-800">All Appointments</h2>
                <span class="text-gray-500"><%= appointments.length %> appointments</span>
            </div>
            <div class="p-6">
                <% if (appointments.length > 0) { %>
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead>
                                <tr class="text-left text-gray-500 text-sm border-b">
                                    <th class="pb-3">Date</th>
                                    <th class="pb-3">Time</th>
                                    <th class="pb-3">Doctor</th>
                                    <th class="pb-3">Patient</th>
                                    <th class="pb-3">Phone</th>
                                    <th class="pb-3">Reason</th>
                                    <th class="pb-3">Status</th>
                                    <th class="pb-3">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y">
                                <% appointments.forEach(function(apt) { %>
                                <tr class="hover:bg-gray-50">
                                    <td class="py-3"><%= apt.date.split('-').reverse().join('/') %></td>
                                    <td class="py-3 font-medium"><%= apt.time %></td>
                                    <td class="py-3"><%= apt.doctorName %></td>
                                    <td class="py-3"><%= apt.patientName %></td>
                                    <td class="py-3"><%= apt.patientPhone %></td>
                                    <td class="py-3 text-gray-500 text-sm max-w-xs truncate"><%= apt.reason %></td>
                                    <td class="py-3">
                                        <form method="POST" action="/admin/appointments/update/<%= apt.id %>" class="inline">
                                            <select name="status" onchange="this.form.submit()" class="text-xs px-2 py-1 rounded-full border-0
                                                <%= apt.status === 'scheduled' ? 'bg-blue-100 text-blue-700' : 
                                                   apt.status === 'completed' ? 'bg-green-100 text-green-700' : 
                                                   'bg-red-100 text-red-700' %>">
                                                <option value="scheduled" <%= apt.status === 'scheduled' ? 'selected' : '' %>>Scheduled</option>
                                                <option value="completed" <%= apt.status === 'completed' ? 'selected' : '' %>>Completed</option>
                                                <option value="cancelled" <%= apt.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                                            </select>
                                        </form>
                                    </td>
                                    <td class="py-3">
                                        <button onclick="showWhatsapp('<%= apt.id %>')" class="text-green-600 hover:text-green-800 mr-2" title="Send on WhatsApp">
                                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                                            </svg>
                                        </button>
                                        <% if (apt.status !== 'cancelled') { %>
                                        <button onclick="cancelAppointment('<%= apt.id %>')" class="text-red-600 hover:text-red-800" title="Cancel">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                            </svg>
                                        </button>
                                        <% } %>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <p class="text-gray-500 text-center py-8">No appointments found</p>
                <% } %>
            </div>
        </div>
    </div>

    <!-- WhatsApp Modal -->
    <div id="whatsappModal" class="fixed inset-0 bg-black/50 hidden flex items-center justify-center p-4 z-50">
        <div class="bg-white rounded-xl max-w-lg w-full">
            <div class="px-6 py-4 border-b flex justify-between items-center">
                <h3 class="text-xl font-bold text-gray-800">Send on WhatsApp</h3>
                <button onclick="closeWhatsapp()" class="text-gray-500 hover:text-gray-700">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
            <div class="p-6">
                <div class="mb-4">
                    <label class="block text-gray-700 font-medium mb-2">Select Language</label>
                    <div class="flex gap-4">
                        <label class="flex items-center">
                            <input type="radio" name="whatsappLang" value="en" checked onchange="updateWhatsappMessage()">
                            <span class="ml-2">English</span>
                        </label>
                        <label class="flex items-center">
                            <input type="radio" name="whatsappLang" value="ur" onchange="updateWhatsappMessage()">
                            <span class="ml-2">اردو</span>
                        </label>
                    </div>
                </div>
                <div class="mb-4">
                    <label class="block text-gray-700 font-medium mb-2">Message Preview</label>
                    <textarea id="whatsappMessage" rows="8" class="w-full px-4 py-3 border rounded-lg bg-gray-50 text-sm" readonly></textarea>
                </div>
                <div class="flex space-x-4">
                    <button onclick="copyMessage()" class="flex-1 bg-gray-200 text-gray-700 py-3 rounded-lg hover:bg-gray-300 transition">Copy Message</button>
                    <a id="whatsappLink" href="#" target="_blank" class="flex-1 bg-green-600 text-white py-3 rounded-lg hover:bg-green-700 transition text-center">Open WhatsApp</a>
                </div>
            </div>
        </div>
    </div>

    <script>
        let currentAppointment = null;

        async function showWhatsapp(id) {
            const res = await fetch('/api/appointment/' + id + '/whatsapp');
            currentAppointment = await res.json();
            updateWhatsappMessage();
            document.getElementById('whatsappModal').classList.remove('hidden');
        }

        function updateWhatsappMessage() {
            if (!currentAppointment) return;
            
            const lang = document.querySelector('input[name="whatsappLang"]:checked').value;
            const apt = currentAppointment.appointment;
            const doctor = currentAppointment.doctor;
            const hospital = currentAppointment.hospital;
            
            let message = '';
            if (lang === 'en') {
                message = `Appointment Confirmed

Doctor: ${doctor.name_en} (${doctor.specialization_en})
Date: ${apt.date.split('-').reverse().join('/')}
Time: ${apt.time}
Patient: ${apt.patientName}
Hospital: ${hospital.name_en}
Phone: ${hospital.phone}`;
            } else {
                message = `اپوائنٹمنٹ کی تصدیق

ڈاکٹر: ${doctor.name_ur} (${doctor.specialization_ur})
تاریخ: ${apt.date.split('-').reverse().join('/')}
وقت: ${apt.time}
مریض: ${apt.patientName}
ہسپتال: ${hospital.name_ur}
فون: ${hospital.phone}`;
            }
            
            document.getElementById('whatsappMessage').value = message;
            
            const phone = apt.patientPhone.replace(/[^0-9]/g, '');
            const whatsappUrl = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
            document.getElementById('whatsappLink').href = whatsappUrl;
        }

        function closeWhatsapp() {
            document.getElementById('whatsappModal').classList.add('hidden');
        }

        function copyMessage() {
            const textarea = document.getElementById('whatsappMessage');
            textarea.select();
            document.execCommand('copy');
            alert('Message copied!');
        }

        function cancelAppointment(id) {
            if (confirm('Are you sure you want to cancel this appointment?')) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '/admin/appointments/cancel/' + id;
                document.body.appendChild(form);
                form.submit();
            }
        }
    </script>
</body>
</html>
