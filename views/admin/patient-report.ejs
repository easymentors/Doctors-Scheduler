<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Patient-Wise Report - Hospital Doctors Scheduler</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .nav-scroll::-webkit-scrollbar { display: none; }
    </style>
</head>
<body class="bg-gray-100 min-h-screen">
    <!-- Header -->
    <header class="bg-white shadow-sm border-b">
        <div class="max-w-7xl mx-auto px-2 sm:px-4 py-3 sm:py-4 flex justify-between items-center">
            <div class="flex items-center space-x-2 sm:space-x-3">
                <div class="w-8 h-8 sm:w-10 sm:h-10 bg-teal-600 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 sm:w-6 sm:h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                    </svg>
                </div>
                <span class="text-lg sm:text-xl font-bold text-gray-800">Hospital Doctors' Scheduler</span>
            </div>
            <div class="flex items-center space-x-2 sm:space-x-4">
                <span class="text-xs sm:text-base text-gray-600 hidden sm:inline"><%= user.name %></span>
                <a href="/logout" class="bg-gray-200 px-2 sm:px-4 py-2 rounded-lg text-gray-700 hover:bg-gray-300 transition text-sm">Logout</a>
            </div>
        </div>
    </header>

    <div class="max-w-7xl mx-auto px-2 sm:px-4 py-4 sm:py-8">
        <!-- Navigation -->
        <div class="flex flex-nowrap sm:flex-wrap sm:space-x-2 gap-2 mb-4 sm:mb-8 overflow-x-auto pb-2 -mx-2 px-2 sm:mx-0 sm:px-0">
            <a href="/admin/dashboard" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">Dashboard</a>
            <% if (user.role === 'admin') { %>
            <a href="/admin/doctors" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">Doctors</a>
            <a href="/admin/doctor-report" class="px-3 sm:px-6 py-2 sm:py-3 bg-purple-100 text-purple-700 rounded-lg font-medium hover:bg-purple-200 text-sm sm:text-base whitespace-nowrap">Doctor Report</a>
            <a href="/admin/patient-report" class="px-3 sm:px-6 py-2 sm:py-3 bg-teal-600 text-white rounded-lg font-medium text-sm sm:text-base whitespace-nowrap">Patient Report</a>
            <% } %>
            <a href="/admin/appointments" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">Appointments</a>
            <a href="/admin/book" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">Book</a>
            <% if (user.role === 'admin') { %>
            <a href="/admin/settings" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">Settings</a>
            <% } %>
        </div>

        <!-- Page Title -->
        <div class="mb-4 sm:mb-6">
            <h1 class="text-xl sm:text-2xl font-bold text-gray-800">Patient-Wise Report</h1>
            <p class="text-gray-500">View appointments grouped by patient</p>
        </div>

        <!-- Search Filter -->
        <div class="bg-white rounded-xl shadow-sm border p-6 mb-6">
            <form method="GET" action="/admin/patient-report" class="flex flex-wrap gap-4 items-end">
                <div>
                    <label class="block text-gray-600 text-sm mb-1">Patient Name</label>
                    <input type="text" name="searchName" value="<%= searchName %>" placeholder="Search by name..." class="px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                </div>
                <div>
                    <label class="block text-gray-600 text-sm mb-1">Phone Number</label>
                    <input type="text" name="searchPhone" value="<%= searchPhone %>" placeholder="Search by phone..." class="px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                </div>
                <button type="submit" class="bg-teal-600 text-white px-6 py-2 rounded-lg hover:bg-teal-700 transition">Search</button>
                <a href="/admin/patient-report" class="bg-gray-200 text-gray-700 px-6 py-2 rounded-lg hover:bg-gray-300 transition">Clear</a>
            </form>
        </div>

        <!-- Patient Reports -->
        <% if (patientReport.length > 0) { %>
            <% patientReport.forEach(function(patient) { %>
            <div class="bg-white rounded-xl shadow-sm border mb-4">
                <!-- Patient Header -->
                <div class="p-6">
                    <div class="flex justify-between items-center">
                        <div>
                            <h3 class="text-xl font-bold text-gray-800"><%= patient.patientName %></h3>
                            <p class="text-teal-600 font-medium"><%= patient.patientPhone %></p>
                        </div>
                        <div class="flex space-x-2" role="group">
                            <button onclick="filterAppointments('<%= patient.patientPhone %>', 'all')" data-filter="all" class="filter-btn px-4 py-2 rounded-lg bg-gray-200 text-gray-700 font-medium hover:bg-gray-300 transition" id="btn-<%= patient.patientPhone %>-all">See All (<%= patient.appointments.length %>)</button>
                            <button onclick="filterAppointments('<%= patient.patientPhone %>', 'scheduled')" data-filter="scheduled" class="filter-btn px-4 py-2 rounded-lg bg-blue-100 text-blue-700 font-medium hover:bg-blue-200 transition" id="btn-<%= patient.patientPhone %>-scheduled">Scheduled (<%= patient.appointments.filter(a => a.status === 'scheduled').length %>)</button>
                            <button onclick="filterAppointments('<%= patient.patientPhone %>', 'completed')" data-filter="completed" class="filter-btn px-4 py-2 rounded-lg bg-green-100 text-green-700 font-medium hover:bg-green-200 transition" id="btn-<%= patient.patientPhone %>-completed">Completed (<%= patient.appointments.filter(a => a.status === 'completed').length %>)</button>
                            <button onclick="filterAppointments('<%= patient.patientPhone %>', 'cancelled')" data-filter="cancelled" class="filter-btn px-4 py-2 rounded-lg bg-red-100 text-red-700 font-medium hover:bg-red-200 transition" id="btn-<%= patient.patientPhone %>-cancelled">Cancelled (<%= patient.appointments.filter(a => a.status === 'cancelled').length %>)</button>
                        </div>
                    </div>
                </div>
                
                <!-- Appointments Table -->
                <div class="px-6 pb-6">
                    <div class="flex items-center justify-between mb-3">
                        <h4 class="font-semibold text-gray-700" id="filterTitle-<%= patient.patientPhone %>">All Appointments (<%= patient.appointments.length %>)</h4>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-sm">
                            <thead>
                                <tr class="text-left text-gray-500 border-b">
                                    <th class="pb-2">Date</th>
                                    <th class="pb-2">Time</th>
                                    <th class="pb-2">Doctor</th>
                                    <th class="pb-2">Reason</th>
                                    <th class="pb-2">Status</th>
                                </tr>
                            </thead>
                            <tbody id="table-<%= patient.patientPhone %>">
                                <% patient.appointments.forEach(function(apt) { %>
                                <tr class="border-b border-gray-200 filter-row" data-status="<%= apt.status %>">
                                    <td class="py-2"><%= apt.date.split('-').reverse().join('/') %></td>
                                    <td class="py-2 font-medium"><%= apt.time %></td>
                                    <td class="py-2"><%= apt.doctorName %></td>
                                    <td class="py-2 text-gray-600"><%= apt.reason %></td>
                                    <td class="py-2">
                                        <span class="px-2 py-1 rounded-full text-xs font-medium
                                            <%= apt.status === 'scheduled' ? 'bg-blue-100 text-blue-700' : 
                                               apt.status === 'completed' ? 'bg-green-100 text-green-700' : 
                                               'bg-red-100 text-red-700' %>">
                                            <%= apt.status.charAt(0).toUpperCase() + apt.status.slice(1) %>
                                        </span>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <% }); %>
        <% } else { %>
        <div class="bg-white rounded-xl shadow-sm border p-12 text-center">
            <p class="text-gray-500">No patients found for the selected search criteria</p>
        </div>
        <% } %>
    </div>

    <script>
        function filterAppointments(phone, filter) {
            const tableId = 'table-' + phone;
            const rows = document.querySelectorAll('#' + tableId + ' .filter-row');
            const filterTitle = document.getElementById('filterTitle-' + phone);
            const allBtn = document.getElementById('btn-' + phone + '-all');
            const scheduledBtn = document.getElementById('btn-' + phone + '-scheduled');
            const completedBtn = document.getElementById('btn-' + phone + '-completed');
            const cancelledBtn = document.getElementById('btn-' + phone + '-cancelled');
            
            allBtn.className = 'filter-btn px-4 py-2 rounded-lg bg-gray-200 text-gray-700 font-medium hover:bg-gray-300 transition';
            scheduledBtn.className = 'filter-btn px-4 py-2 rounded-lg bg-blue-100 text-blue-700 font-medium hover:bg-blue-200 transition';
            completedBtn.className = 'filter-btn px-4 py-2 rounded-lg bg-green-100 text-green-700 font-medium hover:bg-green-200 transition';
            cancelledBtn.className = 'filter-btn px-4 py-2 rounded-lg bg-red-100 text-red-700 font-medium hover:bg-red-200 transition';
            
            const activeBtn = document.getElementById('btn-' + phone + '-' + filter);
            activeBtn.className = 'filter-btn px-4 py-2 rounded-lg bg-teal-600 text-white font-medium';
            
            let count = 0;
            rows.forEach(row => {
                const status = row.getAttribute('data-status');
                if (filter === 'all' || status === filter) {
                    row.style.display = '';
                    count++;
                } else {
                    row.style.display = 'none';
                }
            });
            
            const titles = {
                'all': 'All Appointments',
                'scheduled': 'Scheduled Appointments',
                'completed': 'Completed Appointments',
                'cancelled': 'Cancelled Appointments'
            };
            filterTitle.textContent = titles[filter] + ' (' + count + ')';
        }
    </script>
</body>
</html>
