<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Appointment - Hospital Doctors Scheduler</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .nav-scroll::-webkit-scrollbar { display: none; }
    </style>
</head>
<body class="bg-gray-100 min-h-screen">
    <!-- Header -->
    <header class="bg-white shadow-sm border-b">
        <div class="max-w-7xl mx-auto px-2 sm:px-4 py-3 sm:py-4 flex justify-between items-center">
            <div class="flex items-center space-x-2 sm:space-x-3">
                <div class="w-8 h-8 sm:w-10 sm:h-10 bg-teal-600 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 sm:w-6 sm:h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                    </svg>
                </div>
                <span class="text-lg sm:text-xl font-bold text-gray-800">Hospital Doctors' Scheduler</span>
            </div>
            <div class="flex items-center space-x-2 sm:space-x-4">
                <span class="text-xs sm:text-base text-gray-600 hidden sm:inline"><%= user.name %></span>
                <a href="/logout" class="bg-gray-200 px-2 sm:px-4 py-2 rounded-lg text-gray-700 hover:bg-gray-300 transition text-sm">Logout</a>
            </div>
        </div>
    </header>

    <div class="max-w-3xl mx-auto px-2 sm:px-4 py-4 sm:py-8">
        <!-- Navigation -->
        <div class="flex flex-nowrap sm:flex-wrap sm:space-x-2 gap-2 mb-4 sm:mb-8 overflow-x-auto pb-2 -mx-2 px-2 sm:mx-0 sm:px-0">
            <a href="/manager/dashboard" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">Dashboard</a>
            <a href="/manager/appointments" class="px-3 sm:px-6 py-2 sm:py-3 bg-white text-gray-700 rounded-lg font-medium hover:bg-gray-50 text-sm sm:text-base whitespace-nowrap">Appointments</a>
            <a href="/manager/book" class="px-3 sm:px-6 py-2 sm:py-3 bg-teal-600 text-white rounded-lg font-medium text-sm sm:text-base whitespace-nowrap">Book</a>
        </div>

        <!-- Booking Form -->
        <div class="bg-white rounded-xl shadow-sm border">
            <div class="px-6 py-4 border-b">
                <h2 class="text-xl font-bold text-gray-800">Book New Appointment</h2>
            </div>
            <form method="POST" action="/manager/appointments/book" class="p-6 space-y-6">
                <!-- Doctor Selection -->
                <div>
                    <label class="block text-gray-700 font-medium mb-2">Select Doctor</label>
                    <select name="doctorId" id="doctorSelect" required onchange="loadSlots()" class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                        <option value="">-- Select Doctor --</option>
                        <% doctors.forEach(function(doc) { %>
                        <option value="<%= doc.id %>"><%= doc.name_en %> - <%= doc.specialization_en %></option>
                        <% }); %>
                    </select>
                </div>

                <!-- Patient Info -->
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-gray-700 font-medium mb-2">Patient Name</label>
                        <input type="text" name="patientName" required class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500" placeholder="Enter patient name">
                    </div>
                    <div>
                        <label class="block text-gray-700 font-medium mb-2">Patient Phone</label>
                        <input type="tel" name="patientPhone" required class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500" placeholder="e.g., +92-300-1234567">
                    </div>
                </div>

                <!-- Reason -->
                <div>
                    <label class="block text-gray-700 font-medium mb-2">Reason for Visit</label>
                    <input type="text" name="reason" required class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500" placeholder="e.g., Annual checkup, Follow-up">
                </div>

                <!-- Date & Time -->
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-gray-700 font-medium mb-2">Select Date</label>
                        <input type="date" name="date" id="dateSelect" required onchange="loadSlots()" class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                    </div>
                    <div>
                        <label class="block text-gray-700 font-medium mb-2">Available Time Slots</label>
                        <select name="time" id="timeSelect" required class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                            <option value="">Select date first</option>
                        </select>
                    </div>
                </div>

                <!-- Submit -->
                <div class="flex space-x-4">
                    <button type="submit" class="flex-1 bg-teal-600 text-white py-3 rounded-lg font-medium hover:bg-teal-700 transition">Book Appointment</button>
                    <a href="/manager/appointments" class="flex-1 bg-gray-200 text-gray-700 py-3 rounded-lg font-medium hover:bg-gray-300 transition text-center">Cancel</a>
                </div>
            </form>
        </div>
    </div>

    <script>
        // Set minimum date to today
        const today = new Date().toISOString().split('T')[0];
        document.getElementById('dateSelect').min = today;

        async function loadSlots() {
            const doctorId = document.getElementById('doctorSelect').value;
            const date = document.getElementById('dateSelect').value;
            const timeSelect = document.getElementById('timeSelect');
            
            if (!doctorId || !date) {
                timeSelect.innerHTML = '<option value="">Select date first</option>';
                return;
            }
            
            try {
                const res = await fetch('/manager/api/slots/' + doctorId + '/' + date);
                const slots = await res.json();
                
                if (slots.length === 0) {
                    timeSelect.innerHTML = '<option value="">No slots available</option>';
                } else {
                    timeSelect.innerHTML = '<option value="">-- Select Time --</option>';
                    slots.forEach(slot => {
                        timeSelect.innerHTML += '<option value="' + slot + '">' + slot + '</option>';
                    });
                }
            } catch (err) {
                console.error(err);
                timeSelect.innerHTML = '<option value="">Error loading slots</option>';
            }
        }
    </script>
</body>
</html>
