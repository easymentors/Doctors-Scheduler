<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Super Admin Dashboard - Hospital Doctors' Scheduler</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-gray-100 min-h-screen">
    <header class="bg-white shadow-sm border-b">
        <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
            <div class="flex items-center space-x-3">
                <div class="w-10 h-10 bg-teal-600 rounded-lg flex items-center justify-center">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                    </svg>
                </div>
                <span class="text-xl font-bold text-gray-800">Hospital Doctors' Scheduler</span>
            </div>
            <div class="flex items-center space-x-4">
                <span class="text-gray-600">Super Admin</span>
                <a href="/super-admin/logout" class="bg-gray-200 px-4 py-2 rounded-lg text-gray-700 hover:bg-gray-300 transition">Logout</a>
            </div>
        </div>
    </header>

    <div class="max-w-7xl mx-auto px-4 py-8">
        <h1 class="text-2xl font-bold text-gray-800 mb-8">Super Admin Dashboard</h1>

        <% if (error) { %>
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-6">
                <%= error %>
            </div>
        <% } %>

        <div class="bg-white rounded-xl shadow-sm border p-6 mb-8">
            <h2 class="text-xl font-bold text-gray-800 mb-4">Add New Hospital</h2>
            <form method="POST" action="/super-admin/hospitals/add" enctype="multipart/form-data" class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-gray-700 font-medium mb-2">Hospital Name</label>
                        <input type="text" name="name" required class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500" placeholder="City General Hospital">
                    </div>
                    <div>
                        <label class="block text-gray-700 font-medium mb-2">Subdomain (URL Slug)</label>
                        <input type="text" name="slug" required class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500" placeholder="city-hospital">
                        <p class="text-gray-500 text-sm mt-1">URL will be: yourdomain.com/city-hospital/...</p>
                    </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-gray-700 font-medium mb-2">Admin Username</label>
                        <input type="text" name="adminUsername" required class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500" placeholder="admin">
                    </div>
                    <div>
                        <label class="block text-gray-700 font-medium mb-2">Admin Password</label>
                        <input type="text" name="adminPassword" required class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500" placeholder="admin123">
                    </div>
                </div>
                <div>
                    <label class="block text-gray-700 font-medium mb-2">Hospital Logo (Optional)</label>
                    <input type="file" name="logo" accept="image/jpeg,image/jpg,image/png,image/svg+xml" class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                    <p class="text-gray-500 text-sm mt-1">Allowed: JPG, PNG, SVG (Max 2MB)</p>
                </div>
                <button type="submit" class="bg-teal-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-teal-700 transition">
                    Create Hospital
                </button>
            </form>
        </div>

        <div class="bg-white rounded-xl shadow-sm border p-6">
            <h2 class="text-xl font-bold text-gray-800 mb-4">Registered Hospitals</h2>
            <% if (hospitals.length > 0) { %>
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead>
                            <tr class="text-left text-gray-500 text-sm border-b">
                                <th class="pb-3">ID</th>
                                <th class="pb-3">Name</th>
                                <th class="pb-3">Slug</th>
                                <th class="pb-3">Created</th>
                                <th class="pb-3">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y">
                            <% hospitals.forEach(function(hospital) { %>
                            <tr>
                                <td class="py-3"><%= hospital.id %></td>
                                <td class="py-3 font-medium"><%= hospital.name %></td>
                                <td class="py-3"><%= hospital.slug %></td>
                                <td class="py-3 text-gray-500"><%= new Date(hospital.created_at).toLocaleDateString() %></td>
                                <td class="py-3">
                                    <a href="/<%= hospital.slug %>/login" class="text-teal-600 hover:text-teal-800">Login</a>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <p class="text-gray-500 text-center py-8">No hospitals registered yet</p>
            <% } %>
        </div>
    </div>
</body>
</html>
